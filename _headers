# Cloudflare Pages custom response headers

# JSON content files — never cache, always serve fresh so CMS changes appear immediately
/content/*
  Cache-Control: no-store, max-age=0

# Static assets — cache aggressively
/Assets/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS revalidate on every load (cheap 304s via ETag) so design
# changes appear immediately after deploy instead of being cached 24h.
/style.css
  Cache-Control: public, max-age=0, must-revalidate

/main.js
  Cache-Control: public, max-age=0, must-revalidate
